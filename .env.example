# نسخ إلى .env وتعديل القيم
# قاعدة البيانات (Supabase): استخدم كلمة مرور قاعدة البيانات من لوحة Supabase → Project Settings → Database (Database password)
# وليس كلمة مرور حسابك. أي رموز خاصة في كلمة المرور يجب ترميزها (مثلاً المسافة = %20).
# Session pooler (للتطوير أو السيرفر العادي):
DATABASE_URL="postgresql://postgres.PROJECT_REF:[DATABASE-PASSWORD]@aws-1-eu-west-1.pooler.supabase.com:5432/postgres"
# للنشر على Netlify/Serverless استخدم Transaction mode (منفذ 6543) وأضف pgbouncer:
# DATABASE_URL="postgresql://postgres.PROJECT_REF:[DATABASE-PASSWORD]@aws-1-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
ADMIN_SESSION_SECRET="change-this-admin-session-secret"

# Supabase Storage (رفع الصور من لوحة الأدمن)
NEXT_PUBLIC_SUPABASE_URL="https://PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your_publishable_key"
# مفتاح سري للخادم فقط — من Supabase → Settings → API → Secret keys (default)
SUPABASE_SERVICE_ROLE_KEY="your_service_role_or_secret_key"
